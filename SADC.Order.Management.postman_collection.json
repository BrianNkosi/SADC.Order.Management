{
  "info": {
    "name": "SADC Order Management API",
    "description": "API collection for SADC Order Management system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5120"
    },
    {
      "key": "bearerToken",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/healthz",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/readiness",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/customers",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Company (Pty) Ltd.\",\n  \"email\": \"test@company.co.za\",\n  \"countryCode\": \"ZA\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('customerId', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/customers/{{customerId}}"
          }
        },
        {
          "name": "Search Customers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers?search=test&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"],
              "query": [
                { "key": "search", "value": "test" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"currencyCode\": \"ZAR\",\n  \"lineItems\": [\n    {\n      \"productSku\": \"PROD-STEEL-005\",\n      \"quantity\": 10,\n      \"unitPrice\": 250.00\n    },\n    {\n      \"productSku\": \"PROD-COPPER-003\",\n      \"quantity\": 5,\n      \"unitPrice\": 180.50\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('orderId', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          }
        },
        {
          "name": "List Orders (All)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "List Orders (By Customer)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?customerId={{customerId}}&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "customerId", "value": "{{customerId}}" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "List Orders (By Status: Pending)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?status=Pending&page=1&pageSize=20&sortBy=created&descending=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "status", "value": "Pending" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "sortBy", "value": "created" },
                { "key": "descending", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Update Order Status (Pending → Paid)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newStatus\": \"Paid\"\n}"
            }
          }
        },
        {
          "name": "Update Order Status (Paid → Fulfilled)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newStatus\": \"Fulfilled\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "ZAR Conversion Report",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reports/orders/zar"
          }
        }
      ]
    }
  ]
}
